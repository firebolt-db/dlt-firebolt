# Firebolt service account (Settings → Service accounts)
FIREBOLT_CLIENT_ID=
FIREBOLT_CLIENT_SECRET=
FIREBOLT_ACCOUNT_NAME=
FIREBOLT_DATABASE=
FIREBOLT_ENGINE=

# Staging mode: upload (default, no S3) or s3 (COPY INTO from bucket)
# Managed production: use s3. Upload works on Firebolt Core today.
FIREBOLT_STAGING_MODE=upload

# Firebolt Core (local) — no service account required
# FIREBOLT_USE_CORE=1
# FIREBOLT_CORE_URL=http://localhost:3473
# FIREBOLT_CORE_DATABASE=firebolt

# S3 mode only — must match CREATE LOCATION in Firebolt
# FIREBOLT_STAGING_MODE=s3
# FIREBOLT_S3_LOCATION_NAME=firebolt_s3
# S3_BUCKET=
# S3_PREFIX=dlt-landing
# AWS_PROFILE=sandbox
